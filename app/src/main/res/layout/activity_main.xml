<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F7">

    <!-- CABECERA -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tvSaludo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Hola, Carmelo!"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#1C1C1E"/>

            <TextView
                android:id="@+id/tvFechaHoy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIERNES, 20 de marzo de 2026"
                android:textSize="15sp"
                android:textColor="#6E6E73"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_persona"
                android:background="@drawable/bg_avatar_circle"
                android:padding="10dp"
                android:contentDescription="Foto de perfil"/>

            <TextView
                android:id="@+id/tvNombreAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carmelo"
                android:textSize="13sp"
                android:textColor="#1C1C1E"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- TU RUTINA DE HOY -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TU RUTINA DE HOY:"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1C1C1E"
        android:paddingStart="20dp"
        android:paddingBottom="10dp"/>

    <!-- ZONA TARJETAS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/containerRutinasHoy"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvVacioHoy"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No hay actividades para hoy"
        android:textSize="18sp"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- 4 BOTONES fijos abajo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp"
        android:paddingTop="8dp">

        <!-- Fila 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- ACTIVIDADES -->
            <LinearLayout
                android:id="@+id/btnActividades"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:background="@drawable/bg_card_blue"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_blue"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_calendario"
                        android:layout_gravity="center"
                        android:contentDescription=""/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVIDADES"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"/>
            </LinearLayout>

            <!-- RECORDATORIOS -->
            <LinearLayout
                android:id="@+id/btnRecordatorios"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:background="@drawable/bg_card_green"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_green"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_cita"
                        android:layout_gravity="center"
                        android:contentDescription=""/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECORDATORIOS"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Fila 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:orientation="horizontal">

            <!-- JUEGOS -->
            <LinearLayout
                android:id="@+id/btnJuegos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:background="@drawable/bg_card_orange"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_orange"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_puzzle"
                        android:layout_gravity="center"
                        android:contentDescription=""/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JUEGOS"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"/>
            </LinearLayout>

            <!-- AJUSTES -->
            <LinearLayout
                android:id="@+id/btnAjustes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:background="@drawable/bg_card_purple"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle_purple"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_ajustes"
                        android:layout_gravity="center"
                        android:contentDescription=""/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AJUSTES"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>