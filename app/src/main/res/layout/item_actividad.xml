<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/itemActividadRoot"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Píldora hora -->
    <TextView
        android:id="@+id/tvHoraItem"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:minWidth="80dp"
        android:text="09:00"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/bg_hora_pill"
        android:layout_marginEnd="18dp"/>

    <!-- Nombre del tipo -->
    <TextView
        android:id="@+id/tvTipoItem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="MEDICACIÓN"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"/>

    <!-- EDITAR -->
    <FrameLayout
        android:id="@+id/btnEditarItem"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_btn_editar_circle"
        android:layout_marginEnd="10dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Editar">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_editar"
            android:contentDescription=""/>
    </FrameLayout>

    <!-- ELIMINAR -->
    <FrameLayout
        android:id="@+id/btnEliminarItem"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_btn_eliminar_circle"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Eliminar">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_eliminar"
            android:contentDescription=""/>
    </FrameLayout>

</LinearLayout>