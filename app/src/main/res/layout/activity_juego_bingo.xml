<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- CONTENIDO NORMAL DEL JUEGO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F8F9FA">

        <include layout="@layout/include_top_back_banner" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.1" />

            <include
                android:id="@+id/bocadillo_robot_bingo"
                layout="@layout/include_robot_bocadillo" />

            <TextView
                android:id="@+id/tvFeedbackBingo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MARCA LA TARJETA CORRECTA"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="#5A5A5A"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:id="@+id/contenedorTarjetasBingo"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.3"
                android:orientation="vertical">

                <!-- Fila 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="18dp">

                    <LinearLayout
                        android:id="@+id/btnBingoMedicacion"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_blue"
                        android:padding="18dp"
                        android:foregroundGravity="center">

                        <ImageView
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_marginBottom="12dp"
                            android:src="@drawable/ic_medicacion" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pastillas"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnBingoComida"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_green"
                        android:padding="18dp"
                        android:foregroundGravity="center">

                        <ImageView
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_marginBottom="12dp"
                            android:src="@drawable/ic_comida" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Comida"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Fila 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:id="@+id/btnBingoCalendario"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_purple"
                        android:padding="18dp"
                        android:foregroundGravity="center">

                        <ImageView
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_marginBottom="12dp"
                            android:src="@drawable/ic_calendario" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calendario"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnBingoDormir"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_orange"
                        android:padding="18dp"
                        android:foregroundGravity="center">

                        <ImageView
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:layout_marginBottom="12dp"
                            android:src="@drawable/ic_dormir" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Descanso"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- CAPA OSCURA MODAL -->
    <View
        android:id="@+id/overlayAvisoBingo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- POP-UP SUPERPUESTO -->
    <LinearLayout
        android:id="@+id/panelAvisoErrorBingo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="80dp"
        android:layout_marginEnd="80dp"
        android:minHeight="260dp"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="42dp"
        android:background="@drawable/bg_tipo_normal"
        android:elevation="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvMensajeErrorBingo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mensaje de error"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:textAlignment="center"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="80dp" />

        <Button
            android:id="@+id/btnEntendidoBingo"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:text="ENTENDIDO"
            android:background="@drawable/bg_btn_anadir"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textAllCaps="false" />
    </LinearLayout>

</FrameLayout>