<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/include_top_back_banner" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <!-- Empuja un poco el contenido hacia abajo -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.4" />

        <!-- Robot + bocadillo -->
        <include
            android:id="@+id/bocadillo_robot_bingo"
            layout="@layout/include_robot_bocadillo" />

        <!-- Feedback -->
        <TextView
            android:id="@+id/tvFeedbackBingo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡MARCA LA TARJETA QUE CORRESPONDA!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#6A6A6A"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp" />

        <!-- Rejilla de tarjetas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.3"
            android:orientation="vertical">

            <!-- Fila 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="18dp">

                <!-- Tarjeta 1 -->
                <LinearLayout
                    android:id="@+id/btnBingoMedicacion"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_blue"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/ic_medicacion" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pastillas"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Tarjeta 2 -->
                <LinearLayout
                    android:id="@+id/btnBingoComida"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_green"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/ic_comida" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comida"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Fila 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Tarjeta 3 -->
                <LinearLayout
                    android:id="@+id/btnBingoCalendario"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_purple"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/ic_calendario" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calendario"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Tarjeta 4 -->
                <LinearLayout
                    android:id="@+id/btnBingoDormir"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_card_orange"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_marginBottom="12dp"
                        android:src="@drawable/ic_dormir" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descanso"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Separación antes del botón -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- Botón Bingo -->
        <Button
            android:id="@+id/btnGritarBingo"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp"
            android:text="¡BINGO!"
            android:background="#CCCCCC"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>