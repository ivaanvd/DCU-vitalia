<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F7">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TODOS LOS RECORDATORIOS:"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1C1C1E"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"/>

    <!-- Lista scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/containerRecordatorios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"/>
    </ScrollView>

    <!-- Mensaje vacío -->
    <TextView
        android:id="@+id/tvVacioRecordatorios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No hay recordatorios futuros.\n¡Añade el primero!"
        android:textSize="16sp"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- Botón AÑADIR centrado abajo, igual que en Actividades -->
    <LinearLayout
        android:id="@+id/btnAnadirRecordatorio"
        android:layout_width="260dp"
        android:layout_height="60dp"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_btn_anadir"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Añadir recordatorio">

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_circle_white"
            android:layout_marginEnd="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="+"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1F3D7A"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AÑADIR"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"/>
    </LinearLayout>

</LinearLayout>