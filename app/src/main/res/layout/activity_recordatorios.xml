<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F7">

    <include layout="@layout/include_top_back_banner" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="18dp"
        android:paddingStart="16dp"
        android:paddingEnd="10dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:scrollbarStyle="outsideInset">

        <LinearLayout
            android:id="@+id/containerRecordatorios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="6dp"
            android:paddingBottom="16dp"/>
    </ScrollView>

    <TextView
        android:id="@+id/tvVacioRecordatorios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No hay recordatorios futuros.\n¡Añade el primero!"
        android:textSize="16sp"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/btnAnadirRecordatorio"
        android:layout_width="340dp"
        android:layout_height="70dp"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_btn_anadir"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Añadir recordatorio">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle_white"
            android:layout_marginEnd="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="+"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1F3D7A"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AÑADIR"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"/>
    </LinearLayout>

</LinearLayout>