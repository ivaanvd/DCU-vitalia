<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="600dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center">

        <!-- Robot Emotion Frame -->
        <FrameLayout
            android:id="@+id/frameRobotEmotion"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_icon_circle_blue"
            android:layout_marginBottom="24dp">
            
            <ImageView
                android:id="@+id/ivRobotEmotion"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_calendario"/>
        </FrameLayout>

        <!-- Titulo y Descripcion -->
        <TextView
            android:id="@+id/tvPopupTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡ES HORA DE COMER!"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1C1C1E"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvPopupDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toca comerse la cena."
            android:textSize="18sp"
            android:textColor="#6E6E73"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvPopupDuracion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duración estimada: 30 min"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#4A90E2"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnPopupHacerAhora"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="HACER AHORA"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_guardar"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnPopupPosponer"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="POSPONER 30 MIN"
                android:textColor="#1C1C1E"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_cancelar"
                android:backgroundTint="#FFF59D"/>

        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btnPopupCerrar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:text="✕"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1C1C1E"
        android:gravity="center"
        android:background="@drawable/bg_tipo_normal"
        android:clickable="true"
        android:focusable="true"/>

</FrameLayout>
