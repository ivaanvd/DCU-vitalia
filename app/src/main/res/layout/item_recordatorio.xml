<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/itemRecordatorioRoot"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:background="@drawable/bg_recordatorio_item"
    android:clickable="true"
    android:focusable="true">

    <!-- Píldora oscura: hora + fecha -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/bg_hora_pill_dark"
        android:layout_marginEnd="18dp">

        <TextView
            android:id="@+id/tvHoraItemRec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:00"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvFechaItemRec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="17/02/2026"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#CCCCCC"/>
    </LinearLayout>

    <!-- Título -->
    <TextView
        android:id="@+id/tvTituloItemRec"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="CITA MÉDICA"
        android:textSize="19sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- EDITAR -->
    <FrameLayout
        android:id="@+id/btnEditarItemRec"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_btn_editar_circle"
        android:layout_marginEnd="10dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Editar">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_editar"
            android:contentDescription=""/>
    </FrameLayout>

    <!-- ELIMINAR -->
    <FrameLayout
        android:id="@+id/btnEliminarItemRec"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_btn_eliminar_circle"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Eliminar">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_eliminar"
            android:contentDescription=""/>
    </FrameLayout>

</LinearLayout>