<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/include_top_back_banner" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <!-- Empuja un poco el contenido hacia abajo -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.8" />

        <!-- Contador de aciertos -->
        <TextView
            android:id="@+id/tvContadorAciertos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3/4 refranes acertados"
            android:textColor="#198754"
            android:textSize="60sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- Robot + bocadillo -->
        <include
            android:id="@+id/bocadillo_robot_resultado"
            layout="@layout/include_robot_bocadillo" />

        <!-- Separación -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- Botón jugar otra vez -->
        <Button
            android:id="@+id/btnJugarOtraVez"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="40dp"
            android:text="Jugar otra vez"
            android:background="@drawable/bg_btn_anadir"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <!-- Botón volver al menú -->
        <Button
            android:id="@+id/btnVolverMenu"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="Volver al menú"
            android:background="@drawable/bg_tipo_normal"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <!-- Aire abajo -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.5" />

    </LinearLayout>

</LinearLayout>