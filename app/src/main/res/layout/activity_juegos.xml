<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/include_top_back_banner" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <Button
                android:id="@+id/btnRefranes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="14dp"
                android:background="@drawable/bg_card_blue"
                android:text="REFRANES"
                android:textColor="@android:color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center" />

            <Button
                android:id="@+id/btnBuscaEncuentra"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="14dp"
                android:background="@drawable/bg_card_green"
                android:text="BUSCA Y&#10;ENCUENTRA"
                android:textColor="@android:color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <Button
                android:id="@+id/btnMiniRosco"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="14dp"
                android:background="@drawable/bg_card_orange"
                android:text="MINI-ROSCO&#10;DE LETRAS"
                android:textColor="@android:color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center" />

            <Button
                android:id="@+id/btnBingo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="14dp"
                android:background="@drawable/bg_card_purple"
                android:text="BINGO"
                android:textColor="@android:color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:gravity="center" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>