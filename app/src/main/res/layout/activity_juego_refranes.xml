<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/include_top_back_banner" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp">

        <!-- Fila superior: nombre de la tarea + estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="COMPLETAR REFRANES"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#4A4A4A" />

            <TextView
                android:id="@+id/tvEstadoPregunta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREGUNTA 1 DE 4"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#7A7A7A" />
        </LinearLayout>

        <!-- Robot + bocadillo -->
        <include
            android:id="@+id/bocadillo_robot"
            layout="@layout/include_robot_bocadillo" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="62dp" />

        <!-- Instrucción -->
        <TextView
            android:id="@+id/tvInstruccionRefran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ELIGE LA RESPUESTA CORRECTA"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#4A4A4A"
            android:gravity="start"
            android:layout_marginBottom="40dp" />

        <!-- Opción 1 -->
        <Button
            android:id="@+id/btnOpcion1"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:layout_marginBottom="60dp"
            android:text="Ayuda"
            android:background="@drawable/bg_tipo_normal"
            android:textColor="#111111"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <!-- Opción 2 -->
        <Button
            android:id="@+id/btnOpcion2"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:text="Mira"
            android:background="@drawable/bg_tipo_normal"
            android:textColor="#111111"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>