<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/include_top_back_banner" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <!-- Empuja un poco el contenido hacia abajo -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.7" />

        <!-- Robot + bocadillo -->
        <include
            android:id="@+id/bocadillo_robot_busca"
            layout="@layout/include_robot_bocadillo" />

        <!-- Texto auxiliar -->
        <TextView
            android:id="@+id/tvMensajeAuxiliarBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REVISA ATENTAMENTE LA CUADRÍCULA INFERIOR"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#6A6A6A"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="28dp" />

        <!-- Rejilla más grande -->
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:columnCount="3"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <ImageButton
                android:id="@+id/btnBuscaMedicacion"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_margin="28dp"
                android:background="@drawable/bg_card_orange"
                android:src="@drawable/ic_medicacion"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:contentDescription="Medicacion" />

            <ImageButton
                android:id="@+id/btnBuscaComida"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_margin="28dp"
                android:background="@drawable/bg_card_orange"
                android:src="@drawable/ic_comida"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:contentDescription="Comida" />

            <ImageButton
                android:id="@+id/btnBuscaAjustes"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_margin="28dp"
                android:background="@drawable/bg_card_orange"
                android:src="@drawable/ic_ajustes"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:contentDescription="Ajustes" />

            <ImageButton
                android:id="@+id/btnBuscaCalendario"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_margin="28dp"
                android:background="@drawable/bg_card_orange"
                android:src="@drawable/ic_calendario"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:contentDescription="Calendario" />

            <ImageButton
                android:id="@+id/btnBuscaDormir"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_margin="28dp"
                android:background="@drawable/bg_card_orange"
                android:src="@drawable/ic_dormir"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:contentDescription="Dormir" />

            <ImageButton
                android:id="@+id/btnBuscaOtros"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_margin="28dp"
                android:background="@drawable/bg_card_orange"
                android:src="@drawable/ic_otros"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:contentDescription="Otros" />
        </GridLayout>

        <!-- Aire abajo -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>