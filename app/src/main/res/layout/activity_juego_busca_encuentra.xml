<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Cabecera interna -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BUSCA Y ENCUENTRA"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/tvEstadoBusca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 DE 1"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#777777" />
        </LinearLayout>

        <include
            android:id="@+id/bocadillo_robot_busca"
            layout="@layout/include_robot_bocadillo" />

        <TextView
            android:id="@+id/tvMensajeAuxiliarBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AHORA RECUERDA DÓNDE ESTABA EL ICONO"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="start"
            android:textColor="#6A6A6A"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="32dp" />

        <GridLayout
            android:id="@+id/gridBusca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:columnCount="3"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <ImageButton
                android:id="@+id/btnBuscaMedicacion"
                android:layout_width="170dp"
                android:layout_height="120dp"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_margin="18dp"
                android:background="@drawable/bg_tipo_normal"
                android:contentDescription="Tarjeta 1"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_otros" />

            <ImageButton
                android:id="@+id/btnBuscaComida"
                android:layout_width="170dp"
                android:layout_height="120dp"
                android:layout_margin="18dp"
                android:background="@drawable/bg_tipo_normal"
                android:src="@drawable/ic_otros"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:contentDescription="Tarjeta 2" />

            <ImageButton
                android:id="@+id/btnBuscaAjustes"
                android:layout_width="170dp"
                android:layout_height="120dp"
                android:layout_margin="18dp"
                android:background="@drawable/bg_tipo_normal"
                android:src="@drawable/ic_otros"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:contentDescription="Tarjeta 3" />

            <ImageButton
                android:id="@+id/btnBuscaCalendario"
                android:layout_width="170dp"
                android:layout_height="120dp"
                android:layout_margin="18dp"
                android:background="@drawable/bg_tipo_normal"
                android:src="@drawable/ic_otros"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:contentDescription="Tarjeta 4" />

            <ImageButton
                android:id="@+id/btnBuscaDormir"
                android:layout_width="170dp"
                android:layout_height="120dp"
                android:layout_margin="18dp"
                android:background="@drawable/bg_tipo_normal"
                android:src="@drawable/ic_otros"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:contentDescription="Tarjeta 5" />

            <ImageButton
                android:id="@+id/btnBuscaOtros"
                android:layout_width="170dp"
                android:layout_height="120dp"
                android:layout_margin="18dp"
                android:background="@drawable/bg_tipo_normal"
                android:src="@drawable/ic_otros"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:contentDescription="Tarjeta 6" />
        </GridLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>