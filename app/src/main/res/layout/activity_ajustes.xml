<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="0dp" android:background="#F8F9FA">
    <include layout="@layout/include_top_back_banner" />
    <Space android:layout_width="match_parent" android:layout_height="24dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_input" android:padding="16dp" android:layout_marginBottom="16dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Volumen del robot" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
        <SeekBar android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:max="100" android:progress="75"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_input" android:padding="16dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Brillo de la pantalla" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
        <SeekBar android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:max="100" android:progress="50"/>
    </LinearLayout>
    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
</LinearLayout>
