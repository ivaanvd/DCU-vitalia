<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/include_top_back_banner" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="50dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="VOLUMEN"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="42dp"
            android:background="@drawable/bg_ajuste_mockup_card">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:contentDescription="" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="18dp"
                android:text="Volumen del robot"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/btnMenosVolumen"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="−"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true" />

            <EditText
                android:id="@+id/etVolumen"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="3"
                android:text="70"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <TextView
                android:id="@+id/btnMasVolumen"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="+"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BRILLO"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:background="@drawable/bg_ajuste_mockup_card">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:contentDescription="" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="18dp"
                android:text="Brillo de la pantalla"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/btnMenosBrillo"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="−"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true" />

            <EditText
                android:id="@+id/etBrillo"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="3"
                android:text="60"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <TextView
                android:id="@+id/btnMasBrillo"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="+"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Separador visual -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="30dp" />

        <!-- Botón Borrar Cuenta -->
        <Button
            android:id="@+id/btnBorrarCuenta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Borrar Cuenta y Datos"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_tipo_incorrecto"
            android:textAllCaps="false" />

    </LinearLayout>
</LinearLayout>