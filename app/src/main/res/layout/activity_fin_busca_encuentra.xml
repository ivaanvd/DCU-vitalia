<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡MISIÓN CUMPLIDA!"
            android:textColor="#5A5A5A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="36dp" />

        <TextView
            android:id="@+id/tvTituloExitoBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡Has encontrado lo que buscaba!"
            android:textColor="#198754"
            android:textSize="54sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <include
            android:id="@+id/bocadillo_robot_busca_fin"
            layout="@layout/include_robot_bocadillo" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="60dp" />

        <Button
            android:id="@+id/btnJugarOtraVez"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="40dp"
            android:text="Jugar otra vez"
            android:background="@drawable/bg_btn_anadir"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnVolverMenu"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:text="Volver al menú"
            android:background="@drawable/bg_tipo_normal"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.5" />

    </LinearLayout>

</LinearLayout>