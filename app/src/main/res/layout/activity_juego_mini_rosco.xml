<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/tvTemaRosco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEMÁTICA: FLORA Y PLANTAS"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#5A5A5A"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:gravity="start" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:id="@+id/llContenedorLetras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/tvProgresoLetra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <include
            android:id="@+id/bocadillo_robot_rosco"
            layout="@layout/include_robot_bocadillo" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnRoscoOpcion1"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Opción 1"
                android:background="@drawable/bg_tipo_normal"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnRoscoOpcion2"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Opción 2"
                android:background="@drawable/bg_tipo_normal"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textAllCaps="false" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>